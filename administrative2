<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Technician Map</title>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Supabase -->
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <!-- Mapbox -->
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.1.2/mapbox-gl.css" rel="stylesheet">
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.1.2/mapbox-gl.js"></script>

  <style>
    body {
      margin: 0;
      font-family: Inter, sans-serif;
      background: url('/bg/dashboard-blur.jpg') center/cover no-repeat fixed;
      color: white;
      display: flex;
      min-height: 100vh;
      overflow: hidden;
    }

    .container {
      display: flex;
      width: 100%;
      height: 100vh;
      backdrop-filter: blur(12px);
    }

    /* SIDEBAR */
    .sidebar {
      width: 90px;
      background: rgba(255,255,255,0.08);
      border-right: 1px solid rgba(255,255,255,0.15);
      display: flex;
      flex-direction: column;
      align-items: center;
      padding-top: 25px;
      gap: 25px;
      backdrop-filter: blur(20px);
    }

    .sidebar-icon {
      width: 38px;
      cursor: pointer;
      transition: 0.3s ease;
      animation: pulseGlow 3s infinite ease-in-out;
    }

    @keyframes pulseGlow {
      0% { filter: drop-shadow(0 0 6px rgba(255,255,255,0.4)); transform: scale(1); }
      50% { filter: drop-shadow(0 0 12px rgba(255,255,255,0.7)); transform: scale(1.08); }
      100% { filter: drop-shadow(0 0 6px rgba(255,255,255,0.4)); transform: scale(1); }
    }

    /* MAIN CONTENT */
    .content {
      flex: 1;
      padding: 40px;
      overflow-y: auto;
    }

    .glass-card {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.25);
      border-radius: 18px;
      padding: 30px;
      backdrop-filter: blur(15px);
      margin-bottom: 25px;
      box-shadow: 0 0 25px rgba(255,255,255,0.08);
    }

    #map {
      width: 100%;
      height: 500px;
      border-radius: 18px;
      margin-top: 20px;
    }

    .marker {
      width: 22px;
      height: 22px;
      background: #F5C15C;
      border-radius: 50%;
      border: 3px solid white;
      box-shadow: 0 0 12px rgba(245,193,92,0.6);
      cursor: pointer;
    }

    @media(max-width:900px){
      .sidebar { width: 70px; }
      .content { padding: 20px; }
      #map { height: 350px; }
    }
  </style>
</head>

<body>

<div class="container">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <img src="/icons/home.png" class="sidebar-icon">
    <img src="/icons/dashboard.png" class="sidebar-icon">
    <img src="/icons/technician.png" class="sidebar-icon">
    <img src="/icons/clients.png" class="sidebar-icon">
    <img src="/icons/jobs.png" class="sidebar-icon">
    <img src="/icons/billing.png" class="sidebar-icon">
    <img src="/icons/settings.png" class="sidebar-icon">
    <img src="/icons/logout.png" class="sidebar-icon">
  </div>

  <!-- MAIN CONTENT -->
  <div class="content">

    <div class="glass-card">
      <h1 style="font-family:'Playfair Display', serif;">Service Map</h1>
      <p style="opacity:0.7;">View job locations in your service area</p>
    </div>

    <div class="glass-card">
      <h2 style="font-family:'Playfair Display', serif;">Nearby Jobs</h2>
      <div id="map"></div>
    </div>

  </div>
</div>

<script>
  mapboxgl.accessToken = "YOUR_MAPBOX_KEY";

  const supabaseClient = supabase.createClient(
    "YOUR_SUPABASE_URL",
    "YOUR_SUPABASE_KEY"
  );

  let map;

  function initMap() {
    map = new mapboxgl.Map({
      container: "map",
      style: "mapbox://styles/mapbox/dark-v11",
      center: [-83.8088, 39.9242], // Springfield OH
      zoom: 10
    });

    loadJobMarkers();
  }

  async function loadJobMarkers() {
    const { data, error } = await supabaseClient
      .from("jobs")
      .select("*")
      .eq("status", "open");

    if (error) return console.error(error);

    data.forEach(job => {
      const el = document.createElement("div");
      el.className = "marker";

      el.onclick = () => {
        window.location.href = "/technician/job-details.html?id=" + job.id;
      };

      new mapboxgl.Marker(el)
        .setLngLat([job.lng, job.lat])
        .addTo(map);
    });
  }

  initMap();
</script>

</body>
</html>
